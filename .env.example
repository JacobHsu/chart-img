# ==========================================
# 專案環境變數設定檔 (Environment Configuration)
# ==========================================
# 請將此檔案複製為 .env 並填入您的真實資料
# Please copy this file to .env and fill in your actual credentials
# ==========================================

# [必要] Chart IMG 服務 API Key
# 用途：用於 generating TradingView charts
# 取得方式：https://chart-img.com/
CHART_IMG_API_KEY=

# [必要] Telegram Bot Token
# 用途：用於 Bot 發送訊息與圖片
# 取得方式：在 Telegram 中與 @BotFather對話
TELEGRAM_BOT_TOKEN=

# [必要] Telegram Chat ID
# 用途：接收訊息的目標聊天室 ID
# 取得方式：可以使用 @userinfobot 查詢您的 ID
TELEGRAM_CHAT_ID=

# [必要] NVIDIA NIM API Key
# 用途：用於呼叫 NVIDIA NIM Vision 模型 (meta/llama-3.2-90b-vision-instruct) 分析圖表
# 取得方式：https://build.nvidia.com/ → 登入 → API Keys
NVIDIA_API_KEY=

# [選填] 預設監控幣種 (Default: ETHUSDT)
SYMBOL=ETHUSDT

# [選填] K線週期 (Default: 1h)
# 支援格式：15m, 1h, 4h, 1d 等
INTERVAL=1h
